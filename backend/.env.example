# Copy to .env and fill in. The app boots without a Groq key (template fallback),
# but the AI Counselor and AI comparison summary are best with one.

# Deployment environment: development | staging | production
# In production the app refuses to boot with the default JWT_SECRET.
ENVIRONMENT=development
LOG_LEVEL=INFO

# Auth — CHANGE THIS in any real deployment.
JWT_SECRET=college-kurchi-dev-secret-change-in-prod
JWT_EXPIRE_MINUTES=10080

# Groq LLM (OpenAI-compatible Llama inference)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=900
LLM_TIMEOUT_S=30
LLM_MAX_RETRIES=2

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=college_kurchi
MONGO_MAX_POOL_SIZE=50
MONGO_TIMEOUT_MS=5000

# Embeddings
EMBEDDING_BACKEND=hashing       # hashing | st
EMBEDDING_DIM=512
ST_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunking (RAG pre-processing): window size + overlap in words
CHUNK_MAX_WORDS=60
CHUNK_OVERLAP_WORDS=15

CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:4173
DATA_DIR=../data
