# College Kurchi — static deployment env.
#
# Both vars are OPTIONAL. Without a Groq key the AI Counselor and the
# comparison summary fall back to built-in deterministic templates and the
# site still works fully offline.
#
# WARNING: VITE_ vars are baked into the shipped JavaScript and are PUBLICLY
# visible to anyone who opens the site. A key here can be extracted and abused.
# Use a Groq key with usage limits, and set it in Vercel's Environment
# Variables UI (Project → Settings → Environment Variables) rather than
# committing it. Free Groq keys: https://console.groq.com/keys

VITE_GROQ_API_KEY=
VITE_GROQ_MODEL=llama-3.3-70b-versatile
